# ============================================================================
# SAFS v6.0 Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# === ANTHROPIC API (Claude Opus 4/Haiku/Sonnet) ===
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model selection
SAFS_FIX_GENERATOR_MODEL=claude-opus-4    # Fix generation (Stage 6)
SAFS_ROOT_CAUSE_MODEL=claude-haiku        # Root cause analysis (Stage 3)
SAFS_BUG_LAYER_ROUTER_MODEL=claude-haiku  # Bug layer routing (Stage 0)
SAFS_TEST_GENERATOR_MODEL=claude-sonnet   # Test generation (async)

# === JIRA CONFIGURATION ===
JIRA_URL=https://vizio.atlassian.net
JIRA_USERNAME=safs-bot@vizio.com
JIRA_API_TOKEN=ATATT3xFfGF0...
JIRA_PROJECT_KEY=SMARTCAST

# Jira webhook secret (for validating incoming webhooks)
JIRA_WEBHOOK_SECRET=your-webhook-secret-here

# === QDRANT VECTOR DATABASE ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=  # Leave empty for local dev
QDRANT_HTTPS=false
QDRANT_COLLECTION_HISTORICAL_FIXES=historical_fixes
QDRANT_COLLECTION_FIX_CORRECTIONS=fix_corrections

# === VOYAGE AI (for voyage-code-3 embeddings) ===
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-code-3

# === GITHUB CONFIGURATION (RepositoryAdapter) ===
GITHUB_TOKEN=ghp_...
GITHUB_ORG=buddytv  # Or your org name

# === GITLAB CONFIGURATION (Optional - for private repos) ===
GITLAB_URL=https://gitlab.vizio.com
GITLAB_TOKEN=glpat-...

# === BITBUCKET CONFIGURATION (Optional - for private repos) ===
BITBUCKET_URL=https://bitbucket.vizio.com
BITBUCKET_USERNAME=safs-bot
BITBUCKET_APP_PASSWORD=...

# === POSTGRESQL (for fix_category_stats + companion_lib_versions) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=safs
POSTGRES_USER=safs
POSTGRES_PASSWORD=safs_password

# === REDIS (for pipeline state cache) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty for no auth
REDIS_DB=0

# === TEMPORAL.IO (workflow orchestration) ===
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=safs
TEMPORAL_TASK_QUEUE=safs-pipeline

# === VIZIO TV DEVICE CONFIGURATION (for on-device validation) ===
# Dev TV credentials (for vizio-mcp integration)
VIZIO_TV_IP=192.168.1.100
VIZIO_TV_SSH_PORT=22
VIZIO_TV_SSH_USER=root
VIZIO_TV_SSH_PASSWORD=vizio123  # Or use SSH key
VIZIO_TV_SSH_KEY_PATH=~/.ssh/vizio_tv_rsa

# SCPL pairing (for vizio-remote MCP)
VIZIO_SCPL_AUTH_TOKEN=Zmh4a2pzZGtoZmtzZGhma3Nkamhm

# LOKi TCP port (for vizio-loki MCP)
VIZIO_LOKI_TCP_PORT=4242

# === MCP SERVER CONFIGURATION ===
# Path to vizio-mcp servers (from POC)
VIZIO_REMOTE_MCP_PATH=../mcp_tv_controller/vizio-mcp/vizio-remote
VIZIO_SSH_MCP_PATH=../mcp_tv_controller/vizio-mcp/vizio-ssh
VIZIO_LOKI_MCP_PATH=../mcp_tv_controller/vizio-mcp/vizio-loki

# === CODE-INDEX-MCP (for semantic code search - PATH B) ===
CODE_INDEX_MCP_URL=http://localhost:8080
CODE_INDEX_PVC_PATH=/mnt/code-index-data

# === SYMBOL STORE (MinIO/S3 for .so.debug ELFs + .js.map files) ===
SYMBOL_STORE_ENDPOINT=http://localhost:9000
SYMBOL_STORE_ACCESS_KEY=minioadmin
SYMBOL_STORE_SECRET_KEY=minioadmin
SYMBOL_STORE_BUCKET=vizio-symbols

# === ARM TOOLCHAIN PATHS (for QEMU validation - PATH α) ===
ARM_LEGACY_TOOLCHAIN_PATH=/opt/arm-linux-gnueabi-4.9
ARM_CURRENT_TOOLCHAIN_PATH=/opt/arm-linux-gnueabi-9.3
QEMU_ARM_PATH=/usr/bin/qemu-arm-static

# === LANGFUSE (LLM observability) ===
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === PROMETHEUS (metrics export) ===
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091

# === SAFS PIPELINE CONFIGURATION ===
SAFS_ENVIRONMENT=development  # development | staging | production
SAFS_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
SAFS_DRY_RUN=false            # Set to true to skip PR creation

# Rate limiter configuration
SAFS_RATE_LIMIT_P0P1_BUDGET=5  # calls/min for P0/P1 tickets
SAFS_RATE_LIMIT_P2P3_BUDGET=3  # calls/min for P2/P3 tickets

# Confidence thresholds
SAFS_CONFIDENCE_AUTO_PR=0.85          # Auto-create PR
SAFS_CONFIDENCE_PR_WITH_REVIEW=0.65   # Create PR but require review
SAFS_CONFIDENCE_ANALYSIS_ONLY=0.45    # Send analysis, no PR
# Below 0.45: escalate to human

# === REPOSITORY ADAPTER MAPPING ===
# Pattern → Adapter mapping (glob patterns)
REPO_ADAPTER_GITHUB_PATTERN=buddytv/*,vizio-public/*
REPO_ADAPTER_GITLAB_PATTERN=vizio-loki/*,vizio-firmware/*
REPO_ADAPTER_BITBUCKET_PATTERN=vizio-apps/*

# === TELEMETRY & MONITORING ===
SAFS_PROACTIVE_MONITOR_INTERVAL=300  # seconds (5 min)
SAFS_REGRESSION_MONITOR_WINDOW=72    # hours
SAFS_ERROR_SPIKE_THRESHOLD=2.0       # 2x baseline triggers alert
SAFS_MIN_AFFECTED_USERS=50           # Minimum users for proactive ticket

# === FEATURE FLAGS ===
SAFS_ENABLE_ON_DEVICE_VALIDATION=true
SAFS_ENABLE_BUG_REPRODUCTION=true
SAFS_ENABLE_LLMLINGUA2_COMPRESSION=false  # Optional - only if context > 150K tokens
SAFS_ENABLE_PROACTIVE_MONITORING=true
SAFS_ENABLE_REGRESSION_MONITORING=true

# === TESTING CONFIGURATION ===
PYTEST_TIMEOUT=300  # seconds
PYTEST_PARALLEL_WORKERS=4
